{
  "manifest_version": 3,
  "name": "overhired",
  "version": "1.0.0",
  "description": "Generate personalized cover letters from job postings and auto-fill ATS forms.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:7878/*"
  ],

  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content_scripts/ats/common.js",
        "content_scripts/ats/greenhouse.js",
        "content_scripts/ats/ashby.js",
        "content_scripts/ats/workable.js",
        "content_scripts/ats/icims.js",
        "content_scripts/ats/successfactors.js",
        "content_scripts/ats/generic.js",
        "content_scripts/extractor.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "wasm/mupdf.wasm",
        "wasm/mupdf.js",
        "wasm/mupdf-wasm.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
